# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# MongoDB connection string (required)
# Example: mongodb+srv://username:password@cluster.mongodb.net/appdb?retryWrites=true&w=majority
MONGO_URI=<mongodb-connection-string>

# App server
PORT=5000

# Frontend base URL used in email links (required)
# Example: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Allowed CORS origins (optional but recommended)
# Comma-separated list. If empty, backend allows all origins.
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# JWT settings (required)
JWT_SECRET=<random-long-secret>
JWT_EXPIRE=4h

# Email verification token secret (required)
EMAIL_VERIFICATION_SECRET=<another-random-long-secret>

# SMTP settings (required for register/forgot-password emails)
# Gmail example:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=youraddress@gmail.com
# EMAIL_PASS=<gmail-app-password>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<smtp-username-or-email>
EMAIL_PASS=<smtp-password-or-app-password>
